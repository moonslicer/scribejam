{
  "name": "scribejam",
  "version": "0.1.0",
  "description": "Scribejam desktop app",
  "main": "dist/main/index.js",
  "author": "Scribejam",
  "license": "MIT",
  "scripts": {
    "clean": "rm -rf dist tsconfig.main.tsbuildinfo tsconfig.renderer.tsbuildinfo tsconfig.test.tsbuildinfo",
    "dev": "concurrently -k \"npm:dev:main\" \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:main": "tsc -b tsconfig.main.json --watch --preserveWatchOutput",
    "dev:renderer": "vite",
    "dev:electron": "npm run rebuild-native:electron && wait-on dist/main/index.js http-get://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "npm run clean && npm run build:main && npm run build:renderer",
    "build:main": "tsc -b tsconfig.main.json --force",
    "build:renderer": "vite build",
    "package:mac": "npm run rebuild-native:electron && npm run build && electron-builder --mac dmg",
    "typecheck": "tsc -b",
    "test": "npm run test:node && npm run test:native",
    "test:node": "vitest run --exclude tests/unit/storage-db.test.ts --exclude tests/unit/storage-repositories.test.ts --exclude tests/integration/meeting-records-service.test.ts --exclude tests/integration/enhancement-orchestrator.test.ts",
    "test:native": "cross-env ELECTRON_RUN_AS_NODE=1 electron ./node_modules/vitest/vitest.mjs run tests/unit/storage-db.test.ts tests/unit/storage-repositories.test.ts tests/integration/meeting-records-service.test.ts tests/integration/enhancement-orchestrator.test.ts",
    "smoke": "npm run rebuild-native:electron && node scripts/smoke/startup-smoke.mjs",
    "smoke:playwright": "npm run rebuild-native:electron && npm run build && playwright test tests/smoke --reporter=line",
    "rebuild-native": "npm run rebuild-native:electron",
    "rebuild-native:electron": "electron-rebuild -f",
    "postinstall": "npm run rebuild-native:electron || echo 'native rebuild skipped'"
  },
  "dependencies": {
    "@deepgram/sdk": "^5.0.0",
    "@tiptap/core": "^3.20.1",
    "@tiptap/react": "^3.20.1",
    "@tiptap/starter-kit": "^3.20.1",
    "openai": "^6.27.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.11"
  },
  "optionalDependencies": {
    "audiotee": "^0.0.7",
    "better-sqlite3": "^11.10.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.14.1",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "30.5.1",
    "electron-builder": "^24.13.3",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vite": "^5.4.14",
    "vitest": "^2.1.9",
    "wait-on": "^8.0.3"
  }
}
