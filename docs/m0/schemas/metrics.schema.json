{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scribejam.local/m0/metrics.schema.json",
  "title": "M0 Metrics",
  "type": "object",
  "required": [
    "run_id",
    "duration_minutes",
    "frame_stats",
    "latency_ms",
    "memory_mb",
    "reliability",
    "degradation",
    "privacy"
  ],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "duration_minutes": { "type": "number", "minimum": 0 },
    "frame_stats": {
      "type": "object",
      "required": [
        "total_frames_system",
        "total_frames_mic",
        "total_frames_mixed",
        "dropped_frames_total",
        "dropped_frame_rate_pct"
      ],
      "properties": {
        "total_frames_system": { "type": "integer", "minimum": 0 },
        "total_frames_mic": { "type": "integer", "minimum": 0 },
        "total_frames_mixed": { "type": "integer", "minimum": 0 },
        "dropped_frames_total": { "type": "integer", "minimum": 0 },
        "dropped_frame_rate_pct": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "latency_ms": {
      "type": "object",
      "required": ["p50", "p95", "max"],
      "properties": {
        "p50": { "type": "number", "minimum": 0 },
        "p95": { "type": "number", "minimum": 0 },
        "max": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "memory_mb": {
      "type": "object",
      "required": ["start_rss", "end_rss", "growth_30m"],
      "properties": {
        "start_rss": { "type": "number", "minimum": 0 },
        "end_rss": { "type": "number", "minimum": 0 },
        "growth_30m": { "type": "number" }
      },
      "additionalProperties": false
    },
    "reliability": {
      "type": "object",
      "required": [
        "deepgram_disconnects",
        "deepgram_reconnect_attempts",
        "deepgram_reconnect_successes",
        "capture_stalls_gt_5s"
      ],
      "properties": {
        "deepgram_disconnects": { "type": "integer", "minimum": 0 },
        "deepgram_reconnect_attempts": { "type": "integer", "minimum": 0 },
        "deepgram_reconnect_successes": { "type": "integer", "minimum": 0 },
        "capture_stalls_gt_5s": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "degradation": {
      "type": "object",
      "required": [
        "network_drop_tested",
        "network_drop_recovered",
        "system_capture_unavailable_tested",
        "mic_only_fallback_success"
      ],
      "properties": {
        "network_drop_tested": { "type": "boolean" },
        "network_drop_recovered": { "type": "boolean" },
        "system_capture_unavailable_tested": { "type": "boolean" },
        "mic_only_fallback_success": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "privacy": {
      "type": "object",
      "required": ["raw_audio_files_written"],
      "properties": {
        "raw_audio_files_written": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
